{
  "alias": ["unplanned-escapes.vercel.app"],
  "rewrites": [
    { "source": "/privacy",              "destination": "/privacy.html" },
    { "source": "/changelog",            "destination": "/index.html" },
    { "source": "/explore",              "destination": "/index.html" },
    { "source": "/destinations",         "destination": "/api/destinations/--index--" },
    { "source": "/destinations/:path*",  "destination": "/api/destinations/:path*" },
    { "source": "/api/(.*)",             "destination": "/api/$1" }
  ],
  "crons": [
    { "path": "/api/cron/fuel",      "schedule": "0 18 * * *" },
    { "path": "/api/cron/summaries", "schedule": "0 16 * * 0" }
  ],
  "functions": {
    "api/cron/fuel.ts":      { "maxDuration": 30 },
    "api/cron/summaries.ts": { "maxDuration": 60 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
