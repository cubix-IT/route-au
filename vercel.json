{
  "alias": ["unplanned-escapes.vercel.app"],
  "rewrites": [
    { "source": "/privacy", "destination": "/api/privacy" },
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "crons": [
    { "path": "/api/cron/enrich",    "schedule": "0 1 * * *" },
    { "path": "/api/cron/enrich",    "schedule": "0 18 * * *" },
    { "path": "/api/cron/fuel",      "schedule": "0 17 * * *" },
    { "path": "/api/cron/summaries", "schedule": "0 16 * * 0" },
    { "path": "/api/cron/limits",    "schedule": "0 23 * * 0" }
  ],
  "functions": {
    "api/webhooks/vercel-deploy.ts": { "maxDuration": 10 },
    "api/cron/enrich.ts":    { "maxDuration": 60 },
    "api/cron/fuel.ts":      { "maxDuration": 30 },
    "api/cron/summaries.ts": { "maxDuration": 30 },
    "api/cron/limits.ts":    { "maxDuration": 30 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
