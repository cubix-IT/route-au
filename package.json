{
  "name": "unplanned-escapes-au",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "enrich": "npx tsx --env-file=.env --env-file=.env.local scripts/enrich.ts",
    "deploy": "vercel --prod --yes && npx tsx scripts/log-deploy.mts",
    "db": "npx tsx --env-file=.env --env-file=.env.local scripts/db-query.mts",
    "db:status": "npx tsx --env-file=.env --env-file=.env.local scripts/db-status.mts",
    "cost": "npx tsx --env-file=.env --env-file=.env.local scripts/cost-check.mts",
    "mapcheck": "npx tsx --env-file=.env --env-file=.env.local scripts/map-check.mts",
    "issue-sync": "npx tsx --env-file=.env --env-file=.env.local scripts/issue-sync.mts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.1",
    "@turf/turf": "^7.3.5",
    "@vercel/analytics": "^2.0.1",
    "date-fns": "^4.3.0",
    "idb": "^8.0.3",
    "maplibre-gl": "^5.24.0",
    "pmtiles": "^4.4.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hot-toast": "^2.6.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.8.4",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "osm-pbf-parser": "^2.3.0",
    "playwright": "^1.60.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "through2": "^5.0.1",
    "tsx": "^4.22.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.14",
    "vite-plugin-pwa": "^1.3.0",
    "workbox-window": "^7.4.1"
  }
}
