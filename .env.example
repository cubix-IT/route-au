# ── Unplanned Escapes — Environment Variables ──────────────────────
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.

# ── Supabase (frontend) ─────────────────────────────────────────────
# From: supabase.com → your project → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Mapbox (frontend map tiles) ─────────────────────────────────────
# From: account.mapbox.com → Tokens → your default public token
# Public token — safe to expose in the browser (starts with pk.)
VITE_MAPBOX_TOKEN=pk.eyJ1IjoieW91ci11c2VybmFtZSIsImEiOi...

# ── Server-side only (Vercel API routes & cron) ─────────────────────
# These are NEVER sent to the browser.

# Anthropic API key — for future AI trip planner endpoint
# From: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# Supabase service role key — for cron enrichment writes (bypasses RLS)
# From: supabase.com → your project → Settings → API → service_role key
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Cron secret — any random string, used to protect /api/cron/enrich
# Generate one: openssl rand -hex 32
CRON_SECRET=replace-with-a-long-random-string
